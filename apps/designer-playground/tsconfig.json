{
  "extends": "@silver-formily/typescript-config/base.json",
  "compilerOptions": {
    "target": "ES2022",
    "jsx": "preserve",
    "lib": ["DOM", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "paths": {
      "@silver-formily/core": ["../../packages/core/src/index.ts"],
      "@silver-formily/designer-core": ["../../packages/designer-core/src/index.ts"],
      "@silver-formily/designer-materials-element-plus": ["../../packages/designer-materials-element-plus/src/index.ts"],
      "@silver-formily/designer-vue": ["../../packages/designer-vue/src/index.ts"],
      "@silver-formily/element-plus": ["../../packages/element-plus/src/index.ts"],
      "@silver-formily/grid": ["../../packages/grid/src/index.ts"],
      "@silver-formily/json-schema": ["../../packages/json-schema/src/index.ts"],
      "@silver-formily/path": ["../../packages/path/src/index.ts"],
      "@silver-formily/reactive": ["../../packages/reactive/src/index.ts"],
      "@silver-formily/reactive-vue": ["../../packages/reactive-vue/src/index.ts"],
      "@silver-formily/shared": ["../../packages/shared/src/index.ts"],
      "@silver-formily/validator": ["../../packages/validator/src/index.ts"],
      "@silver-formily/vue": ["../../packages/vue/src/index.ts"]
    },
    "resolveJsonModule": true,
    "types": ["node"],
    "allowJs": false,
    "strict": false,
    "noUnusedLocals": false,
    "declaration": false,
    "emitDeclarationOnly": false,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src", "env.d.ts"],
  "exclude": ["node_modules", "dist"]
}
