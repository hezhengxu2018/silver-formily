{
  "name": "element-plus-docs",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "pnpm run docs:deps && vitepress dev .",
    "docs:deps": "pnpm --dir ../.. exec turbo run build --filter=@silver-formily/grid --filter=@silver-formily/reactive-vue --filter=@silver-formily/vue",
    "preview": "vitepress preview .",
    "lint": "eslint .",
    "format": "eslint . --fix",
    "check-types": "vue-tsc --noEmit",
    "docs:build": "pnpm run docs:deps && vitepress build ."
  },
  "silverFormily": {
    "tasks": {
      "dev": {
        "filterMode": "workspace-only"
      }
    }
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@formily/core": "^2.3.7",
    "@formily/json-schema": "^2.3.7",
    "@formily/reactive": "^2.3.7",
    "@formily/shared": "^2.3.7",
    "@silver-formily/docs-toolkit": "workspace:*",
    "@silver-formily/element-plus": "workspace:*",
    "@silver-formily/grid": "workspace:*",
    "@silver-formily/reactive-vue": "workspace:*",
    "@silver-formily/vue": "workspace:*",
    "@types/lodash-es": "^4.17.12",
    "element-plus": "^2.13.2",
    "lodash-es": "^4.17.23",
    "shiki": "^3.22.0",
    "vue": "^3.3.0",
    "vue-draggable-plus": "^0.5.6"
  },
  "devDependencies": {
    "@silver-formily/typescript-config": "workspace:*",
    "@vitejs/plugin-vue-jsx": "^5.1.3",
    "typescript": "5.9.2",
    "vitepress": "2.0.0-alpha.16"
  }
}
