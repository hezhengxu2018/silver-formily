{
  "name": "reactive-docs",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vitepress dev .",
    "preview": "vitepress preview .",
    "lint": "eslint .",
    "format": "eslint . --fix",
    "check-types": "vue-tsc --noEmit",
