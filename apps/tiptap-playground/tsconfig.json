{
  "extends": "@silver-formily/typescript-config/base.json",
  "compilerOptions": {
    "target": "ES2022",
    "jsx": "preserve",
    "lib": ["DOM", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "types": ["vite/client", "node"]
  },
  "include": ["src/**/*.ts", "src/**/*.vue", "vite.config.ts", "env.d.ts"]
}
