{
  "name": "vue-docs",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "pnpm run docs:deps && vitepress dev .",
    "docs:deps": "node ../../scripts/docs-deps.mjs",
    "preview": "vitepress preview .",
    "lint": "eslint .",
    "format": "eslint . --fix",
    "check-types": "vue-tsc --noEmit",
    "docs:build": "pnpm run docs:deps && vitepress build ."
  },
  "silverFormily": {
    "docs": {
      "buildDependencies": [
        "@silver-formily/reactive-vue"
      ]
    },
    "tasks": {
      "dev": {
        "filterMode": "workspace-only"
      }
    }
  },
  "dependencies": {
    "@element-plus/icons-vue": "catalog:",
    "@formily/core": "catalog:",
    "@formily/json-schema": "catalog:",
    "@formily/reactive": "catalog:",
    "@formily/shared": "catalog:",
    "@silver-formily/docs-toolkit": "workspace:*",
    "@silver-formily/reactive-vue": "workspace:*",
    "@silver-formily/vue": "workspace:*",
    "element-plus": "catalog:",
    "vue": "catalog:conflicts_vue_h3_3_0"
  },
  "devDependencies": {
    "@shikijs/vitepress-twoslash": "catalog:",
    "@silver-formily/typescript-config": "workspace:*",
    "@vitejs/plugin-vue-jsx": "catalog:",
    "typescript": "catalog:",
    "vitepress": "catalog:",
    "vue-tsc": "catalog:"
  }
}
