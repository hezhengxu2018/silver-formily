{
  "name": "@silver-formily/core",
  "type": "module",
  "version": "2.3.7",
  "description": "Silver Formily maintained fork of @formily/core",
  "author": "hezhengxu",
  "license": "MIT",
  "homepage": "https://github.com/hezhengxu2018/silver-formily",
  "repository": {
    "type": "github",
    "url": "https://github.com/hezhengxu2018/silver-formily",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/hezhengxu2018/silver-formily/issues"
  },
  "exports": {
    ".": {
      "types": "./esm/index.d.ts",
      "import": "./esm/index.mjs",
      "default": "./esm/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "main": "./esm/index.mjs",
  "types": "./esm/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "esm"
  ],
  "scripts": {
    "build": "tsdown --tsconfig tsconfig.build.json",
    "lint": "eslint .",
    "format": "eslint . --fix",
    "check-types": "tsc --noEmit --project tsconfig.json && tsc --noEmit --project tsconfig.spec.json",
    "test": "vitest run --reporter=dot",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@silver-formily/reactive": "workspace:*",
    "@silver-formily/shared": "workspace:*",
    "@silver-formily/validator": "workspace:*"
  },
  "devDependencies": {
    "@silver-formily/typescript-config": "workspace:*",
    "@vitest/coverage-istanbul": "catalog:",
    "eslint": "catalog:",
    "oxc-resolver": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
