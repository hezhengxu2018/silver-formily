{
  "name": "@silver-formily/designer-shared",
  "type": "module",
  "version": "0.0.0",
  "description": "Shared utilities for Silver Formily designable packages",
  "author": "hezhengxu",
  "license": "MIT",
  "homepage": "https://github.com/hezhengxu2018/silver-formily",
  "repository": {
    "type": "github",
    "url": "https://github.com/hezhengxu2018/silver-formily",
    "directory": "packages/designer-shared"
  },
  "bugs": {
    "url": "https://github.com/hezhengxu2018/silver-formily/issues"
  },
  "exports": {
    ".": {
      "types": "./esm/index.d.ts",
      "import": "./esm/index.mjs",
      "default": "./esm/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "main": "./esm/index.mjs",
  "types": "./esm/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "esm"
  ],
  "scripts": {
    "build": "tsdown --tsconfig tsconfig.build.json",
    "lint": "eslint .",
    "format": "eslint . --fix",
    "check-types": "tsc --noEmit --project tsconfig.json",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "requestidlecallback": "catalog:"
  },
  "devDependencies": {
    "@silver-formily/typescript-config": "workspace:*",
    "eslint": "catalog:",
    "oxc-resolver": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  }
}
