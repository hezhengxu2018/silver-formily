{
  "name": "@silver-formily/designer-vue",
  "type": "module",
  "version": "0.0.1",
  "description": "Vue 3 designable shell and widgets for Silver Formily designer",
  "author": "hezhengxu",
  "license": "MIT",
  "homepage": "https://github.com/hezhengxu2018/silver-formily",
  "repository": {
    "type": "github",
    "url": "https://github.com/hezhengxu2018/silver-formily",
    "directory": "packages/designer-vue"
  },
  "bugs": {
    "url": "https://github.com/hezhengxu2018/silver-formily/issues"
  },
  "sideEffects": [
    "**/*.css",
    "**/*.vue"
  ],
  "exports": {
    ".": {
      "types": "./esm/index.d.ts",
      "import": "./esm/index.mjs",
      "default": "./esm/index.mjs"
    },
    "./containers": {
      "types": "./esm/containers/index.d.ts",
      "import": "./esm/containers/index.mjs",
      "default": "./esm/containers/index.mjs"
    },
    "./hooks": {
      "types": "./esm/hooks/index.d.ts",
      "import": "./esm/hooks/index.mjs",
      "default": "./esm/hooks/index.mjs"
    },
    "./widgets": {
      "types": "./esm/widgets/index.d.ts",
      "import": "./esm/widgets/index.mjs",
      "default": "./esm/widgets/index.mjs"
    },
    "./context": {
      "types": "./esm/context.d.ts",
      "import": "./esm/context.mjs",
      "default": "./esm/context.mjs"
    },
    "./shared": {
      "types": "./esm/shared/index.d.ts",
      "import": "./esm/shared/index.mjs",
      "default": "./esm/shared/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "main": "./esm/index.mjs",
  "types": "./esm/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "esm"
  ],
  "scripts": {
    "build": "tsdown --tsconfig tsconfig.build.json",
    "dev": "vite --config playground/vite.config.ts",
    "lint": "eslint .",
    "format": "eslint . --fix",
    "check-types": "vue-tsc --noEmit --project tsconfig.json",
    "prepublishOnly": "pnpm run build"
  },
  "peerDependencies": {
    "@lucide/vue": "*",
    "@silver-formily/designer-core": "workspace:*",
    "@silver-formily/reactive": "workspace:*",
    "@silver-formily/reactive-vue": "workspace:*",
    "vue": "^3.3.0"
  },
  "devDependencies": {
    "@lucide/vue": "catalog:",
    "@silver-formily/designer-core": "workspace:*",
    "@silver-formily/reactive": "workspace:*",
    "@silver-formily/reactive-vue": "workspace:*",
    "@silver-formily/typescript-config": "workspace:*",
    "@tailwindcss/postcss": "catalog:",
    "@types/node": "catalog:",
    "@vitejs/plugin-vue": "catalog:",
    "@vitejs/plugin-vue-jsx": "catalog:",
    "eslint": "catalog:",
    "postcss": "catalog:",
    "postcss-nested": "catalog:",
    "tailwindcss": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "unplugin-vue": "catalog:",
    "vite": "catalog:",
    "vue": "catalog:",
    "vue-tsc": "catalog:"
  }
}
