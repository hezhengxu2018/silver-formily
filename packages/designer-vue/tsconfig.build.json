{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "paths": {},
    "declaration": true,
    "emitDeclarationOnly": true,
    "noEmit": false
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.vue",
    "src/**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "esm",
    "src/**/__test__/**",
    "src/**/__tests__/**",
    "src/**/*.test.ts"
  ]
}
