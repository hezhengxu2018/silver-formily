{
  "extends": "@silver-formily/typescript-config/base.json",
  "compilerOptions": {
    "target": "ES2022",
    "jsx": "preserve",
    "lib": ["DOM", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "paths": {
      "@silver-formily/designer-vue": ["./src"],
      "@silver-formily/designer-vue/*": ["./src/*"],
      "@silver-formily/designer-core": ["../designer-core/src"],
      "@silver-formily/designer-core/*": ["../designer-core/src/*"]
    },
    "resolveJsonModule": true,
    "types": ["node"],
    "allowJs": false,
    "strict": false,
    "noUnusedLocals": false,
    "declaration": false,
    "emitDeclarationOnly": false,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "esm"]
}
