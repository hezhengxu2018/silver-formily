    "vitepress-plugin-nprogress": "catalog:",
    "vitepress-theme-element-plus": "catalog:"
  },
  "devDependencies": {
    "@types/markdown-it-container": "catalog:",
    "typescript": "catalog:",
    "vue": "catalog:",
    "vue-tsc": "catalog:"
  }
