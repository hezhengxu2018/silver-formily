{
  "name": "@silver-formily/docs-toolkit",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js"
    },
    "./theme": {
      "types": "./theme/index.d.ts",
      "import": "./theme/index.js"
    }
  },
  "main": "./index.js",
  "types": "./index.d.ts",
  "bin": {
    "vitepress": "./bin/vitepress.js"
  },
  "scripts": {
