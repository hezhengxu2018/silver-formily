{
  "name": "@silver-formily/element-plus",
  "type": "module",
  "version": "3.0.2",
  "description": "Formily 的 Element Plus 封装",
  "author": "hezhengxu",
  "license": "MIT",
  "homepage": "https://element-plus.silver-formily.org/",
  "repository": {
    "type": "github",
    "url": "https://github.com/hezhengxu2018/silver-formily",
    "directory": "packages/element-plus"
  },
  "bugs": {
    "url": "https://github.com/hezhengxu2018/silver-formily/issues"
  },
  "sideEffects": [
    "**/*.css",
    "**/*.scss"
  ],
  "exports": {
    ".": {
      "types": "./esm/index.d.ts",
      "import": "./esm/index.mjs",
      "default": "./esm/index.mjs"
    },
    "./*": "./esm/*",
    "./package.json": "./package.json"
  },
  "main": "./esm/index.mjs",
  "types": "./esm/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "esm"
  ],
  "scripts": {
    "build": "vite build",
    "lint": "eslint .",
    "format": "eslint . --fix",
    "check-types": "vue-tsc --noEmit --project tsconfig.check.json",
    "test": "vitest run --reporter=dot",
    "test:watch": "vitest",
    "test:run": "vitest run --browser.headless",
    "test:coverage": "vitest run --coverage --browser.headless",
    "prepublishOnly": "pnpm run build"
  },
  "peerDependencies": {
    "@formily/core": "^2.0.8",
    "@formily/json-schema": "^2.0.8",
    "@formily/reactive": "^2.0.8",
    "@formily/shared": "^2.0.8",
    "@silver-formily/grid": "^1.0.1",
    "@silver-formily/reactive-vue": "^1.1.0",
    "@silver-formily/vue": "^2.3.1",
    "@vueuse/core": "*",
    "element-plus": "^2.1.8",
    "vue": "^3.3.0"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "vue-draggable-plus": "^0.5.6"
  },
  "devDependencies": {
    "@silver-formily/grid": "workspace:*",
    "@silver-formily/reactive-vue": "workspace:*",
    "@silver-formily/typescript-config": "workspace:*",
    "@silver-formily/vue": "workspace:*",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^24.3.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "@vitest/browser": "^4.1.4",
    "@vitest/browser-playwright": "^4.1.4",
    "@vitest/coverage-istanbul": "^4.1.4",
    "fast-glob": "^3.3.3",
    "lodash-es": "^4.17.23",
    "playwright": "^1.58.2",
    "sass-embedded": "^1.97.3",
    "typescript": "6.0.2",
    "vite": "^8.0.8",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-lib-inject-css": "^2.2.2",
    "vitest": "^4.1.4",
    "vitest-browser-vue": "^2.0.2"
  }
}
