{
  "name": "@silver-formily/grid",
  "type": "module",
  "version": "1.0.2",
  "description": "Responsive grid runtime for Silver Formily",
  "author": "hezhengxu",
  "license": "MIT",
  "homepage": "https://github.com/hezhengxu2018/silver-formily",
  "repository": {
    "type": "github",
    "url": "https://github.com/hezhengxu2018/silver-formily",
    "directory": "packages/grid"
  },
  "bugs": {
    "url": "https://github.com/hezhengxu2018/silver-formily/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown --tsconfig tsconfig.build.json",
    "dev": "tsdown --watch --tsconfig tsconfig.build.json",
    "lint": "eslint .",
    "format": "eslint . --fix",
    "check-types": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --browser.headless",
    "prepublishOnly": "pnpm run build"
  },
  "peerDependencies": {
    "@silver-formily/reactive": "workspace:*"
  },
  "devDependencies": {
    "@silver-formily/reactive": "workspace:*",
    "@silver-formily/typescript-config": "workspace:*",
    "@vitest/browser-playwright": "catalog:",
    "@vitest/coverage-istanbul": "catalog:",
    "eslint": "catalog:",
    "oxc-resolver": "catalog:",
    "playwright": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "vue-tsc": "catalog:"
  }
}
