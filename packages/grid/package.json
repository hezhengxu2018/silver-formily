{
  "name": "@silver-formily/grid",
  "type": "module",
  "version": "0.0.0",
  "description": "Grid package scaffold for silver-formily",
  "author": "hezhengxu",
  "license": "MIT",
  "homepage": "https://github.com/hezhengxu2018/silver-formily",
  "repository": {
    "type": "github",
    "url": "https://github.com/hezhengxu2018/silver-formily",
    "directory": "packages/grid"
  },
  "bugs": {
    "url": "https://github.com/hezhengxu2018/silver-formily/issues"
  },
  "exports": {
    ".": "./dist/demo.mjs",
    "./package.json": "./package.json"
  },
  "main": "./dist/demo.mjs",
  "module": "./dist/demo.mjs",
  "types": "./dist/demo.d.mts",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "eslint .",
    "format": "eslint . --fix",
    "check-types": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "devDependencies": {
    "@silver-formily/typescript-config": "workspace:*",
    "eslint": "^9.36.0",
    "tsdown": "^0.18.1",
    "typescript": "5.9.2"
  }
}
