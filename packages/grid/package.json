{
  "name": "@silver-formily/grid",
  "type": "module",
  "version": "1.0.1",
  "description": "Grid package scaffold for silver-formily",
  "author": "hezhengxu",
  "license": "MIT",
  "homepage": "https://github.com/hezhengxu2018/silver-formily",
  "repository": {
    "type": "github",
    "url": "https://github.com/hezhengxu2018/silver-formily",
    "directory": "packages/grid"
  },
  "bugs": {
    "url": "https://github.com/hezhengxu2018/silver-formily/issues"
  },
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "lint": "eslint .",
    "format": "eslint . --fix",
    "check-types": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --browser.headless",
    "prepublishOnly": "pnpm run build"
  },
  "peerDependencies": {
    "@formily/reactive": "^2"
  },
  "devDependencies": {
    "@formily/reactive": "^2.3.7",
    "@silver-formily/typescript-config": "workspace:*",
    "@vitest/browser-playwright": "^4.1.4",
    "@vitest/coverage-istanbul": "^4.1.4",
    "eslint": "^9.36.0",
    "oxc-resolver": "^11.19.1",
    "playwright": "^1.58.2",
    "typescript": "6.0.2",
    "vite": "^8.0.0",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.4"
  }
}
