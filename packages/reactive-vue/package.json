{
  "name": "@silver-formily/reactive-vue",
  "type": "module",
  "version": "1.1.0",
  "description": "Another @formily/reactive-vue",
  "author": "Hezhengxu",
  "license": "MIT",
  "homepage": "https://reactive-vue.silver-formily.org",
  "repository": {
    "type": "github",
    "url": "https://github.com/hezhengxu2018/silver-formily"
  },
  "bugs": {
    "url": "https://github.com/hezhengxu2018/silver-formily/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown --tsconfig tsconfig.build.json",
    "dev": "tsdown --watch --tsconfig tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --coverage.provider=istanbul --coverage.reporter=clover --coverage.reporter=json --coverage.reporter=html",
    "lint": "eslint .",
    "format": "eslint . --fix",
    "check-types": "vue-tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "peerDependencies": {
    "@formily/reactive": "^2",
    "vue": "^3.3.0"
  },
  "devDependencies": {
    "@formily/reactive": "catalog:",
    "@silver-formily/typescript-config": "workspace:*",
    "@vitest/coverage-istanbul": "catalog:",
    "eslint": "catalog:",
    "oxc-resolver": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "vue": "catalog:",
    "vue-tsc": "catalog:"
  }
}
