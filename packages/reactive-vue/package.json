{
  "name": "@silver-formily/reactive-vue",
  "type": "module",
  "version": "1.1.0",
  "description": "Another @formily/reactive-vue",
  "author": "Hezhengxu",
  "license": "MIT",
  "homepage": "https://reactive-vue.silver-formily.org",
  "repository": {
    "type": "github",
    "url": "https://github.com/hezhengxu2018/silver-formily"
  },
  "bugs": {
    "url": "https://github.com/hezhengxu2018/silver-formily/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --coverage.provider=istanbul --coverage.reporter=clover --coverage.reporter=json --coverage.reporter=html",
    "lint": "eslint .",
    "format": "eslint . --fix",
    "check-types": "vue-tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "peerDependencies": {
    "@formily/reactive": "^2",
    "vue": "^3.3.0"
  },
  "devDependencies": {
    "@formily/reactive": "^2.3.7",
    "@silver-formily/typescript-config": "workspace:*",
    "@vitest/coverage-istanbul": "^4.1.4",
    "eslint": "^9.36.0",
    "oxc-resolver": "^11.19.1",
    "typescript": "6.0.2",
    "vite": "^8.0.8",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.4",
    "vue": "^3.5.27"
  }
}
