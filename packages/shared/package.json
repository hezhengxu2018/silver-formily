{
  "name": "@silver-formily/shared",
  "type": "module",
  "version": "1.0.0",
  "description": "Shared low-level utilities and type helpers for Silver Formily runtime packages",
  "author": "hezhengxu",
  "license": "MIT",
  "homepage": "https://github.com/hezhengxu2018/silver-formily",
  "repository": {
    "type": "github",
    "url": "https://github.com/hezhengxu2018/silver-formily",
    "directory": "packages/shared"
  },
  "bugs": {
    "url": "https://github.com/hezhengxu2018/silver-formily/issues"
  },
  "exports": {
    ".": {
      "types": "./esm/index.d.ts",
      "import": "./esm/index.mjs",
      "default": "./esm/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "main": "./esm/index.mjs",
  "types": "./esm/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "esm"
  ],
  "scripts": {
    "build": "tsdown --tsconfig tsconfig.build.json",
    "lint": "eslint .",
    "format": "eslint . --fix",
    "check-types": "tsc --noEmit --project tsconfig.json && tsc --noEmit --project tsconfig.test.json",
    "test": "vitest run --reporter=dot --browser.headless",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --browser.headless",
    "prepublishOnly": "pnpm run build"
  },
  "devDependencies": {
    "@vitest/browser": "catalog:",
    "@vitest/browser-playwright": "catalog:",
    "@vitest/coverage-istanbul": "catalog:",
    "es-toolkit": "catalog:",
    "eslint": "catalog:",
    "oxc-resolver": "catalog:",
    "playwright": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
