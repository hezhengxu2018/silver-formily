{
  "name": "@silver-formily/vant",
  "type": "module",
  "version": "1.0.0",
  "description": "Vant bindings for Silver Formily",
  "author": "hezhengxu",
  "license": "MIT",
  "homepage": "https://vant.silver-formily.org/",
  "repository": {
    "type": "github",
    "url": "https://github.com/hezhengxu2018/silver-formily",
    "directory": "packages/vant"
  },
  "bugs": {
    "url": "https://github.com/hezhengxu2018/silver-formily/issues"
  },
  "sideEffects": [
    "**/*.css",
    "**/*.scss"
  ],
  "exports": {
    ".": {
      "types": "./esm/index.d.ts",
      "import": "./esm/index.mjs",
      "default": "./esm/index.mjs"
    },
    "./*": "./esm/*",
    "./package.json": "./package.json"
  },
  "main": "./esm/index.mjs",
  "types": "./esm/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "esm"
  ],
  "scripts": {
    "build": "tsdown --tsconfig tsconfig.build.json",
    "lint": "eslint .",
    "format": "eslint . --fix",
    "check-types": "vue-tsc --noEmit --project tsconfig.check.json",
    "test": "vitest run --reporter=dot",
    "test:watch": "vitest",
    "test:browser": "vitest run --browser.headless",
    "test:coverage": "vitest run --coverage --browser.headless",
    "prepublishOnly": "pnpm run build"
  },
  "peerDependencies": {
    "@silver-formily/core": "workspace:*",
    "@silver-formily/json-schema": "workspace:*",
    "@silver-formily/path": "workspace:*",
    "@silver-formily/reactive": "workspace:*",
    "@silver-formily/reactive-vue": "workspace:*",
    "@silver-formily/shared": "workspace:*",
    "@silver-formily/vue": "workspace:*",
    "dayjs": "^1",
    "vant": "^4.9.22",
    "vue": "^3.3.0"
  },
  "dependencies": {
    "easy-bem": "catalog:",
    "es-toolkit": "catalog:"
  },
  "devDependencies": {
    "@silver-formily/core": "workspace:*",
    "@silver-formily/json-schema": "workspace:*",
    "@silver-formily/path": "workspace:*",
    "@silver-formily/reactive": "workspace:*",
    "@silver-formily/reactive-vue": "workspace:*",
    "@silver-formily/shared": "workspace:*",
    "@silver-formily/typescript-config": "workspace:*",
    "@silver-formily/vue": "workspace:*",
    "@tsdown/css": "catalog:",
    "@types/node": "catalog:",
    "@vitejs/plugin-vue": "catalog:",
    "@vitejs/plugin-vue-jsx": "catalog:",
    "@vitest/browser": "catalog:",
    "@vitest/browser-playwright": "catalog:",
    "@vitest/coverage-istanbul": "catalog:",
    "playwright": "catalog:",
    "sass-embedded": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "unplugin-vue": "catalog:",
    "vant": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:",
    "vitest-browser-vue": "catalog:",
    "vue": "catalog:",
    "vue-tsc": "catalog:"
  }
}
