{
  "name": "@silver-formily/vue",
  "type": "module",
  "version": "2.3.3",
  "description": "Vue3 版本的 @formily/vue",
  "author": "hezhengxu",
  "license": "MIT",
  "homepage": "https://vue.silver-formily.org",
  "repository": {
    "type": "github",
    "url": "https://github.com/hezhengxu2018/silver-formily",
    "directory": "packages/vue"
  },
  "bugs": {
    "url": "https://github.com/hezhengxu2018/silver-formily/issues"
  },
  "exports": {
    ".": {
      "types": "./esm/index.d.ts",
      "import": "./esm/index.mjs",
      "default": "./esm/index.mjs"
    },
    "./*": {
      "types": "./esm/*.d.ts",
      "import": "./esm/*.mjs",
      "default": "./esm/*.mjs"
    }
  },
  "main": "./esm/index.mjs",
  "types": "./esm/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "esm"
  ],
  "scripts": {
    "build": "tsdown --tsconfig tsconfig.build.json",
    "lint": "eslint .",
    "format": "eslint . --fix",
    "check-types": "vue-tsc --noEmit",
    "commit": "czg",
    "prepublishOnly": "pnpm run build"
  },
  "peerDependencies": {
    "@formily/core": "^2",
    "@formily/json-schema": "^2",
    "@formily/reactive": "^2",
    "@formily/shared": "^2",
    "@silver-formily/reactive-vue": "^1.0.0",
    "vue": "^3.3.0"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-git"
    }
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:",
    "@commitlint/config-conventional": "catalog:",
    "@formily/validator": "catalog:",
    "@silver-formily/reactive-vue": "workspace:*",
    "@silver-formily/typescript-config": "workspace:*",
    "@types/node": "catalog:",
    "@vue/language-core": "catalog:",
    "@vue/shared": "catalog:",
    "commitlint": "catalog:",
    "cz-git": "catalog:",
    "czg": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-format": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vue": "catalog:",
    "vue-tsc": "catalog:"
  }
}
