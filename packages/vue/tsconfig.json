{
  "extends": "@silver-formily/typescript-config/base.json",
  "compilerOptions": {
    "jsx": "preserve",
    "experimentalDecorators": true,
    "paths": {
      "@silver-formily/reactive-vue": ["../reactive-vue/src"],
      "@silver-formily/reactive-vue/*": ["../reactive-vue/src/*"]
    },
    "declaration": false,
    "emitDeclarationOnly": false,
    "noEmit": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "esm"]
}
